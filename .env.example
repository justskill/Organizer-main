# =============================================================================
# Inventory Catalog System - Environment Variables
# Copy this file to .env and adjust values for your deployment.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory

# --- Backend (FastAPI) ---
INVENTORY_DATABASE_URL=postgresql+asyncpg://inventory:inventory@inventory-db:5432/inventory
INVENTORY_SECRET_KEY=change-me-in-production
INVENTORY_ACCESS_TOKEN_EXPIRE_MINUTES=1440
INVENTORY_ALGORITHM=HS256
INVENTORY_MEDIA_PATH=/data/media
INVENTORY_LABELS_PATH=/data/labels
INVENTORY_MAX_UPLOAD_SIZE_BYTES=52428800
INVENTORY_ALLOWED_ORIGINS=["http://localhost:3000"]
INVENTORY_API_PORT=8000
INVENTORY_DEBUG=false

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000

# --- Ports (host mapping) ---
HOST_API_PORT=8000
HOST_WEB_PORT=3000
HOST_DB_PORT=5432
